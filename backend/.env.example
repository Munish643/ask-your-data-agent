APP_ENV=development
DATABASE_URL=postgresql+psycopg://app:app@postgres:5432/askdata
DATABASE_SSL_MODE=
DATABASE_SSL_ROOT_CERT=
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
REDIS_URL=redis://redis:6379/0
CORS_ORIGINS=http://localhost:3000
STORAGE_DIR=storage
INGESTION_MODE=worker
MAX_UPLOAD_MB=25
ALLOWED_UPLOAD_EXTENSIONS=.txt,.md,.pdf,.docx

GEMINI_API_KEY=
GEMINI_GENERATION_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIMENSION=768
GEMINI_MAX_OUTPUT_TOKENS=500

LLM_TIMEOUT_SECONDS=30
LLM_STREAM_TIMEOUT_SECONDS=60
EMBEDDING_BATCH_SIZE=5
RETRIEVAL_LIMIT=4
RETRIEVAL_SOURCE_CONTENT_CHARS=1400
RETRIEVAL_MIN_SCORE=0.2
FALLBACK_KEYWORD_OVERLAP_MIN=1
WEB_SEARCH_ENABLED=true
WEB_SEARCH_LIMIT=5
WEB_SEARCH_TIMEOUT_SECONDS=8
AUTH_TOKEN_SECRET=dev-change-me-session-secret
AUTH_TOKEN_TTL_SECONDS=86400
AUTH_ALLOW_DEV_FALLBACK=false
